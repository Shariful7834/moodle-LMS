# ─────────────────────────────────────────────────────────────
# Academic Achievement Wallet — server configuration
# Copy this file to `.env` and edit values.
# Defaults work for local development on http://localhost:4000.
# ─────────────────────────────────────────────────────────────

# Runtime mode. In `production` the server REFUSES TO START unless JWT_SECRET
# and SESSION_SECRET are set to non-default values, and session cookies use
# Secure + SameSite=lax (HTTPS required).
NODE_ENV=development

# Backend HTTP port
PORT=4000

# Public base URL used to build dereferenceable credential / achievement / status
# URLs and to derive the issuer did:web identifier.
# Local dev:        http://localhost:4000
# Public demo:      https://wallet.example.com   (e.g. ngrok / Cloudflare tunnel)
ISSUER_BASE_URL=http://localhost:4000

# Optional override of the issuer DID. Leave unset to derive from ISSUER_BASE_URL.
# When set manually it MUST resolve via HTTPS to the corresponding
# /.well-known/did.json or /<path>/did.json (per W3C did:web spec).
# ISSUER_DID=did:web:wallet.example.com:api:badges:issuer

# ── Secrets (REQUIRED in production) ────────────────────────
# Login token signing secret (separate from the ES256 credential signing key,
# which lives under data/keys/ and auto-generates on first boot).
JWT_SECRET=replace-with-a-long-random-secret

# Express session cookie signing secret.
SESSION_SECRET=replace-with-another-long-random-secret

# ── CORS allow-list ─────────────────────────────────────────
# Comma-separated list of allowed front-end Origins. Same-origin / curl /
# server-to-server (no Origin header) is always allowed.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000,http://127.0.0.1:5173

# ── Outbound fetch protection (SSRF + DoS) ──────────────────
# Hosts where the server is allowed to fetch http:// (instead of https://)
# AND to resolve to private/loopback IP ranges. Used for did:web localhost
# development. Comma-separated.
SSRF_LOCAL_ALLOW=localhost,127.0.0.1,::1

# Outbound fetch timeout (ms) — applied to /api/verify URL fetch, did:web
# document resolution, and status list resolution.
FETCH_TIMEOUT_MS=10000

# ── Moodle integration (optional) ───────────────────────────
MOODLE_URL=http://localhost:8080
MOODLE_TOKEN=replace-with-your-moodle-token
